{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "tmux",
  "permissions": {
    "allow": [
      "Bash(poetry *)",
      "Bash(acli *)",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(docker *)"
    ],
    "deny": [
      "Bash(poetry publish *)",
      "Bash(docker push *)"
    ]
  }
}
